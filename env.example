# SEO Environment Variables Template
# Copy this to .env.local and add your actual values

# Basic SEO Settings
NEXT_PUBLIC_APP_URL=https://andgatepos.com
NEXT_PUBLIC_APP_NAME="AndgatePOS"
NEXT_PUBLIC_APP_DESCRIPTION="Complete Point of Sale System for Modern Businesses"

# Search Engine Verification
GOOGLE_SITE_VERIFICATION=your_google_verification_code
BING_SITE_VERIFICATION=your_bing_verification_code
YANDEX_SITE_VERIFICATION=your_yandex_verification_code

# Analytics & Tracking
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# Facebook Pixel ID - Get from: https://business.facebook.com/events_manager
# Your current ID: 1803836553585330 (replace with your actual pixel ID)
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=1803836553585330

# Social Media
NEXT_PUBLIC_FACEBOOK_PAGE=https://facebook.com/andgatepos
NEXT_PUBLIC_TWITTER_HANDLE=@andgatepos
NEXT_PUBLIC_LINKEDIN_PAGE=https://linkedin.com/company/andgate

# Business Information
NEXT_PUBLIC_BUSINESS_NAME="Andgate Technologies"
NEXT_PUBLIC_BUSINESS_ADDRESS="Your Business Address, City, Country"
NEXT_PUBLIC_BUSINESS_PHONE="+1-XXX-XXX-XXXX"
NEXT_PUBLIC_BUSINESS_EMAIL="contact@andgatepos.com"

# OpenGraph Images
NEXT_PUBLIC_OG_IMAGE_URL=https://andgatepos.com/images/og-image.png
NEXT_PUBLIC_LOGO_URL=https://andgatepos.com/assets/images/logo.png

# Performance & Security
NEXT_PUBLIC_CDN_URL=https://cdn.andgatepos.com
NODE_ENV=production